      "isDeleted": false,
      "boundElements": [],
      "updated": 1784179210217,
      "link": null,
      "locked": false,
      "text": "1) Developer/BP submits requests for mount points in ServiceNow",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1) Developer/BP submits requests for mount points in ServiceNow",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "EUE9MrnvbZJTwgvdrZtoK",
      "type": "text",
      "x": 1739.2830489454775,
      "y": 2237.4878647706178,
      "width": 728.1197509765625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0Y",
      "roundness": null,
      "seed": 1502643646,
      "version": 1232,
      "versionNonce": 1890255870,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1784179627566,
      "link": null,
      "locked": false,
      "text": "2) Request is approved/denied by VM owner and fulfills the mount point creation",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2) Request is approved/denied by VM owner and fulfills the mount point creation",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "io2jkIWrhO8Zv2aAWfPRN",
      "type": "text",
      "x": 1738.6937003686046,
      "y": 2274.7249711546915,
      "width": 974.71923828125,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
