      "versionNonce": 1294873534,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1784179389961,
      "link": null,
      "locked": false,
      "text": "3,4) AWX does all the admin activity - checks for space, add disks if required, creates vgs,lvs and fstab entry\n",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3,4) AWX does all the admin activity - checks for space, add disks if required, creates vgs,lvs and fstab entry\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
