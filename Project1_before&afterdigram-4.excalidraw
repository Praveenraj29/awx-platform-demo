    {
      "id": "BqmANi3E9yeYop-go16LO",
      "type": "text",
      "x": 313.618284757898,
      "y": 1151.3886236784285,
      "width": 941.939453125,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aS",
      "roundness": null,
      "seed": 1793508094,
      "version": 1100,
      "versionNonce": 1207887778,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784179729019,
      "link": null,
      "locked": false,
      "text": "1) Developer/BP submits requests for mount points in ServiceNow\n2) Request is picked by admin and manually verified with VM owner and fulfills the mount point creation\n3) Mount activity like disk addition, vg creation, lv creation and fstab entry is performed\n4) Updated the ticket in ServiceNow and closes it\n5) Developer/BP checks the RITM notes for artifacts and acknowledges.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1) Developer/BP submits requests for mount points in ServiceNow\n2) Request is picked by admin and manually verified with VM owner and fulfills the mount point creation\n3) Mount activity like disk addition, vg creation, lv creation and fstab entry is performed\n4) Updated the ticket in ServiceNow and closes it\n5) Developer/BP checks the RITM notes for artifacts and acknowledges.",
      "autoResize": true,
      "lineHeight": 1.25
    },
