      "isDeleted": true,
      "boundElements": [],
      "updated": 1784178358863,
      "link": null,
      "locked": false,
      "text": "1) Developer/BP submits requests for mount points in ServiceNow\n2) Request is picked by admin and fulfills the mount point creation\n3) Mount activity like disk addition, vg creation, lv creation and fstab entry is performed\n4) Updated the ticket in ServiceNow and closes it\n5) Developer/BP checks the RITM notes for approval and acknowledges.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1) Developer/BP submits requests for mount points in ServiceNow\n2) Request is picked by admin and fulfills the mount point creation\n3) Mount activity like disk addition, vg creation, lv creation and fstab entry is performed\n4) Updated the ticket in ServiceNow and closes it\n5) Developer/BP checks the RITM notes for approval and acknowledges.",
      "autoResize": true,
      "lineHeight": 1.25
    },
