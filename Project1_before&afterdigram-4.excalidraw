    {
      "id": "VApUvbaexf-h0v1ytulnC",
      "type": "text",
      "x": 1504.6141436230703,
      "y": 2179.4023636864245,
      "width": 1239.95556640625,
      "height": 197.4853925893148,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
